---
import Layout from '../layouts/Layout.astro';
---

<Layout title="MAFRA Logistics | Transporte de Carga Industrial Nuevo León">
	<main class="pt-20">
		
		<section class="relative min-h-[90vh] flex items-center bg-brand-dark text-white overflow-hidden py-20">
			<div class="absolute inset-0 z-0 opacity-40">
				<img src="/hero-mafra.jpg" alt="Transporte de Carga Industrial Nuevo León" class="w-full h-full object-cover scale-105" />
				<div class="absolute inset-0 bg-gradient-to-r from-brand-dark via-brand-dark/80 to-transparent"></div>
			</div>
			
			<div class="max-w-7xl mx-auto px-6 relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center w-full">
				<div class="lg:col-span-8 hero-text">
					<span class="inline-flex items-center gap-2 px-3 py-1 bg-brand-primary/20 border border-brand-primary/30 text-brand-primary rounded-full text-xs font-semibold tracking-wider uppercase mb-6">
						<span class="w-2 h-2 rounded-full bg-brand-primary animate-pulse"></span> Disponibilidad Inmediata 24/7
					</span>
					<h1 class="text-4xl md:text-6xl font-extrabold tracking-tight mb-6 leading-none">
						Transporte de Carga Industrial en Nuevo León
					</h1>
					<p class="text-lg md:text-xl text-brand-text max-w-2xl mb-8 leading-relaxed">
						Ofrecemos un servicio de fletes de carga confiable para atender tus envíos urgentes en Nuevo León con flota propia. Contamos con disponibilidad inmediata de unidades Nissan, 3.5 toneladas y fletes de trailer para proteger tu línea de producción.
					</p>
					<div class="flex flex-col sm:flex-row gap-4">
						<a href="#cotizar" class="bg-brand-primary hover:bg-red-700 text-white font-bold px-8 py-4 rounded-md text-center transition-all duration-300 shadow-xl shadow-brand-primary/30">
							Cotizar Flete Industrial
						</a>
					</div>
				</div>
			</div>
		</section>

		<section id="por-que-elegirnos" class="py-24 bg-white relative z-10">
			<div class="max-w-7xl mx-auto px-6">
				<div class="text-center max-w-3xl mx-auto mb-16">
					<h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-brand-dark uppercase mb-4">
						¿Por qué debes elegirnos?
					</h2>
					<div class="h-1 w-20 bg-brand-primary mx-auto"></div>
				</div>
				
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="benefit-card bg-brand-light p-8 rounded-xl border border-black/5 hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
						<div class="w-12 h-12 bg-brand-primary/10 rounded-lg flex items-center justify-center mb-6 text-brand-primary text-2xl font-bold">
							<i class="ph-fill ph-shield-check"></i>
						</div>
						<h3 class="text-xl font-bold mb-4 text-brand-dark">Sin Intermediarios</h3>
						<p class="text-brand-secondary text-sm leading-relaxed">
							Oficinas en San Nicolás y salidas de transporte desde Escobedo. No somos un bróker tradicional; garantizamos el <strong class="text-brand-dark">control total y la seguridad</strong> de tu mercancía.
						</p>
					</div>
					<div class="benefit-card bg-brand-light p-8 rounded-xl border border-black/5 hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
						<div class="w-12 h-12 bg-brand-primary/10 rounded-lg flex items-center justify-center mb-6 text-brand-primary text-2xl font-bold">
							<i class="ph-fill ph-clock"></i>
						</div>
						<h3 class="text-xl font-bold mb-4 text-brand-dark">Puntualidad</h3>
						<p class="text-brand-secondary text-sm leading-relaxed">
							Cobertura estratégica y despachos inmediatos hacia los principales puntos industriales de Nuevo León.
						</p>
					</div>
					<div class="benefit-card bg-brand-light p-8 rounded-xl border border-black/5 hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
						<div class="w-12 h-12 bg-brand-primary/10 rounded-lg flex items-center justify-center mb-6 text-brand-primary text-2xl font-bold">
							<i class="ph-fill ph-headset"></i>
						</div>
						<h3 class="text-xl font-bold mb-4 text-brand-dark">Atención 24/7</h3>
						<p class="text-brand-secondary text-sm leading-relaxed">
							Monitoreo y respuesta inmediata. Somos el aliado estratégico en transporte logístico B2B que <strong class="text-brand-dark">responde cuando otros te quedan mal</strong>.
						</p>
					</div>
				</div>
			</div>
		</section>

		<section id="soluciones" class="py-24 bg-gradient-to-b from-brand-secondary to-brand-dark text-white overflow-hidden relative">
			<div class="absolute inset-0 opacity-10 bg-[url('/bento-ftl.jpg')] bg-cover bg-fixed bg-center pointer-events-none"></div>
			<div class="max-w-7xl mx-auto px-6 relative z-10">
				<div class="mb-16">
					<h2 class="text-3xl md:text-4xl font-extrabold tracking-tight uppercase mb-4">
						Soluciones de Carga <span class="text-brand-primary">a tu Medida</span>
					</h2>
					<div class="h-1 w-20 bg-brand-primary"></div>
				</div>

				<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
					<!-- Top Area: Servicio Principal -->
					<div class="bento-item lg:col-span-12 glass-card p-8 md:p-12 rounded-2xl flex flex-col justify-between relative overflow-hidden">
						<div class="relative z-10 w-full">
							<span class="text-xs font-bold text-brand-primary tracking-widest uppercase block mb-2">Nuestro Servicio Principal</span>
							<h3 class="text-2xl md:text-3xl font-extrabold mb-4">Servicio de fletes de carga por viaje</h3>
							<p class="text-white/90 text-sm md:text-base leading-relaxed mb-8 max-w-3xl">
								Nos llamas, confirmamos disponibilidad y asignamos la unidad. Movemos tu carga con cobro por viaje, sin contratos ni compromisos. Ideal para operaciones regulares, urgencias y flete dedicado.
							</p>
							
							<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
								<div class="flex items-center gap-3 text-sm md:text-base font-semibold bg-white/5 p-4 rounded-lg border border-white/10 hover:bg-white/10 transition-colors">
									<i class="ph-fill ph-warning-circle text-2xl text-brand-primary"></i> Urgencias y hotshots
								</div>
								<div class="flex items-center gap-3 text-sm md:text-base font-semibold bg-white/5 p-4 rounded-lg border border-white/10 hover:bg-white/10 transition-colors">
									<i class="ph-fill ph-truck text-2xl text-brand-primary"></i> Unidades 1½ y 3½ ton
								</div>
								<div class="flex items-center gap-3 text-sm md:text-base font-semibold bg-white/5 p-4 rounded-lg border border-white/10 hover:bg-white/10 transition-colors">
									<i class="ph-fill ph-map-pin text-2xl text-brand-primary"></i> Monterrey y zona metropolitana
								</div>
							</div>

							<div class="mt-4 relative z-10">
								<a href="#cotizar" class="inline-block bg-brand-primary hover:bg-red-700 text-white font-bold px-8 py-4 rounded-md text-center transition-all duration-300 shadow-lg shadow-brand-primary/30">
									Solicitar Unidad
								</a>
							</div>
						</div>
					</div>

					<!-- Bottom Area: Ahorro -->
					<div class="bento-item lg:col-span-12 bg-brand-dark p-8 md:p-12 rounded-2xl border border-white/5 relative overflow-hidden">
						<div class="text-center mb-10 relative z-10">
							<h3 class="text-xl md:text-3xl font-extrabold tracking-tight uppercase">
								¿Mueves carga todos los días? <span class="text-brand-primary block md:inline mt-2 md:mt-0">Te ayudamos a ahorrar</span>
							</h3>
						</div>
						
						<div class="grid grid-cols-1 md:grid-cols-2 gap-8 relative z-10">
							<!-- Esquemas de renta -->
							<div class="p-8 rounded-xl border border-white/10 transition-colors">
								<h4 class="text-xl font-bold mb-4 text-white">Esquemas de renta flexibles</h4>
								<p class="text-sm md:text-base text-white/80 mb-6 leading-relaxed">
									Si tu operación requiere 2 o más viajes al día, te ofrecemos renta por jornada (8, 10 o 12 horas) en lugar de pagar de forma individual por cada servicio de fletes.
								</p>
								<ul class="space-y-4 text-sm md:text-base font-medium text-white/90">
									<li class="flex items-start gap-3"><i class="ph-bold ph-check text-brand-primary mt-1 text-lg"></i> Tarifa menor a mayor plazo: día, semana o mes.</li>
									<li class="flex items-start gap-3"><i class="ph-bold ph-check text-brand-primary mt-1 text-lg"></i> Descuentos por volumen de unidades en tus fletes de carga.</li>
								</ul>
							</div>

							<!-- Proyectos de ahorro -->
							<div class="p-8 rounded-xl border border-white/10 transition-colors">
								<h4 class="text-xl font-bold mb-4 text-white">Proyectos de ahorro a la medida</h4>
								<p class="text-sm md:text-base text-white/80 mb-6 leading-relaxed">
									Analizamos tu operación y diseñamos un esquema logístico que reduce directamente tu costo por servicio.
								</p>
								<ul class="space-y-4 text-sm md:text-base font-medium text-white/90">
									<li class="flex items-start gap-3"><i class="ph-bold ph-check text-brand-primary mt-1 text-lg"></i> Enfocado en tus metas de ahorro anual.</li>
									<li class="flex items-start gap-3"><i class="ph-bold ph-check text-brand-primary mt-1 text-lg"></i> Somos socios de proyecto, no solo proveedores.</li>
								</ul>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section id="cotizar" class="py-24 bg-brand-light relative">
			<div class="max-w-4xl mx-auto px-6">
				<div class="bg-white rounded-2xl shadow-xl overflow-hidden grid grid-cols-1 md:grid-cols-12 border border-black/5">
					<div class="md:col-span-5 bg-brand-dark text-white p-8 md:p-12 flex flex-col justify-between relative">
						<div>
							<h2 class="text-2xl md:text-3xl font-extrabold mb-4 uppercase tracking-tight">
								Envía tu <span class="text-brand-primary">cotización</span>
							</h2>
							<p class="text-brand-text text-sm leading-relaxed">
								Le damos prioridad exclusiva a tu cuenta corporativa. Recibe<br />respuesta inmediata de nuestro equipo de despacho.
							</p>
						</div>
						<div class="mt-8 space-y-4 text-xs text-brand-text hidden md:block">
							<p class="flex items-center gap-2"><i class="ph ph-clock-afternoon text-brand-primary text-base"></i> Respuesta en menos de 15 minutos</p>
							<p class="flex items-center gap-2"><i class="ph ph-truck text-brand-primary text-base"></i> Flota propia disponible</p>
						</div>
					</div>
					
					<div class="md:col-span-7 p-8 md:p-12">
						<form id="leadForm" class="space-y-4">
							<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
								<div>
									<label class="block text-xs font-bold uppercase tracking-wider text-brand-secondary mb-1">Nombre</label>
									<input type="text" name="nombre" required class="w-full border border-black/10 rounded p-2.5 text-sm focus:outline-none focus:border-brand-primary bg-brand-light" />
								</div>
								<div>
									<label class="block text-xs font-bold uppercase tracking-wider text-brand-secondary mb-1">Empresa</label>
									<input type="text" name="empresa" required class="w-full border border-black/10 rounded p-2.5 text-sm focus:outline-none focus:border-brand-primary bg-brand-light" />
								</div>
							</div>
							<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
								<div>
									<label class="block text-xs font-bold uppercase tracking-wider text-brand-secondary mb-1">Correo Corporativo</label>
									<input type="email" name="correo" required class="w-full border border-black/10 rounded p-2.5 text-sm focus:outline-none focus:border-brand-primary bg-brand-light" />
								</div>
								<div>
									<label class="block text-xs font-bold uppercase tracking-wider text-brand-secondary mb-1">Teléfono</label>
									<input type="tel" name="telefono" required pattern="[0-9]{10}" placeholder="10 dígitos" class="w-full border border-black/10 rounded p-2.5 text-sm focus:outline-none focus:border-brand-primary bg-brand-light" />
								</div>
							</div>
							<div>
								<label class="block text-xs font-bold uppercase tracking-wider text-brand-secondary mb-1">Tipo de Unidad Requerida</label>
								<select name="unidad" class="w-full border border-black/10 rounded p-2.5 text-sm focus:outline-none focus:border-brand-primary bg-brand-light">
									<option value="Nissan / Pick-up">Nissan / Pick-up</option>
									<option value="3.5 Toneladas (Plataforma/Caja)">3.5 Toneladas (Plataforma/Caja)</option>
									<option value="Rabón (26')">Rabón (26')</option>
									<option value="Caja Seca 53’ / Plataforma">Caja Seca 53’ / Plataforma</option>
									<option value="Refrigerado 53’">Refrigerado 53’</option>
									<option value="Otro / No estoy seguro">Otro / No estoy seguro</option>
								</select>
							</div>
							<div>
								<label class="block text-xs font-bold uppercase tracking-wider text-brand-secondary mb-1">Mercancía a transportar</label>
								<input type="text" name="mercancia" required placeholder="Ej. Acero, Refacciones, Tarimas..." class="w-full border border-black/10 rounded p-2.5 text-sm focus:outline-none focus:border-brand-primary bg-brand-light" />
							</div>
							<div>
								<label class="block text-xs font-bold uppercase tracking-wider text-brand-secondary mb-1">Ruta (Origen/Destino)</label>
								<input type="text" name="ruta" placeholder="Ej. Santa Catarina NL a Laredo TX" class="w-full border border-black/10 rounded p-2.5 text-sm focus:outline-none focus:border-brand-primary bg-brand-light" />
							</div>
							
							<button type="submit" id="submitBtn" class="w-full bg-brand-primary hover:bg-red-700 text-white font-bold py-3.5 rounded transition-all uppercase tracking-wider text-sm shadow-lg shadow-brand-primary/20 flex justify-center items-center gap-2">
								<span id="btnText">Cotizar Ahora</span>
								<div id="btnSpinner" class="hidden w-5 h-5 border-2 border-white border-t-transparent rounded-full animate-spin"></div>
							</button>
							
							<p id="formFeedback" class="hidden text-center text-sm font-semibold mt-2"></p>
						</form>
					</div>
				</div>
			</div>
		</section>

		<section class="py-20 bg-brand-primary text-white text-center relative overflow-hidden">
			<div class="max-w-4xl mx-auto px-6 relative z-10">
				<h2 class="text-3xl md:text-5xl font-extrabold uppercase mb-4 tracking-tight">¿Urgencia de última hora?</h2>
				<p class="text-white/80 max-w-xl mx-auto mb-8 text-sm md:text-base">
					No dejes que se detenga tu cadena de suministro. Te asignamos<br />una unidad de inmediato con control y monitoreo continuo.
				</p>
				<a href="tel:+528129115812" class="inline-flex items-center gap-2 bg-white text-brand-primary hover:bg-brand-light font-bold px-8 py-4 rounded-md transition-all duration-300 shadow-2xl">
					<i class="ph-bold ph-phone-call text-xl"></i> Llamada Directa
				</a>
			</div>
			<div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.2)_0,transparent_70%)]"></div>
		</section>

	</main>

	<script is:inline>
		// Initialize GSAP immediately since script is at the bottom of the body
		if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
			gsap.registerPlugin(ScrollTrigger);

			// Animación inicial Hero
			gsap.from('.hero-text > *', {
				opacity: 0,
				y: 30,
				duration: 1,
				stagger: 0.2,
				ease: 'power3.out'
			});

			/* 
			// Revelado de tarjetas de beneficios - Temporalmente deshabilitado para debug
			gsap.from('.benefit-card', {
				scrollTrigger: {
					trigger: '#por-que-elegirnos',
					start: 'top 85%',
					toggleActions: 'play none none none'
				},
				opacity: 0,
				y: 40,
				duration: 0.8,
				stagger: 0.15,
				ease: 'power2.out'
			});

			// Revelado del Bento Grid
			gsap.from('.bento-item', {
				scrollTrigger: {
					trigger: '#soluciones',
					start: 'top 80%'
				},
				opacity: 0,
				scale: 0.95,
				duration: 0.7,
				stagger: 0.15,
				ease: 'power2.out'
			});
			*/
			
			// Revelado de la sección de contacto
			gsap.from('#cotizar .max-w-6xl', {
				scrollTrigger: {
					trigger: '#cotizar',
					start: 'top 80%'
				},
				opacity: 0,
				y: 50,
				duration: 0.8,
				ease: 'power3.out'
			});
		} else {
			console.error("GSAP or ScrollTrigger not loaded");
		}
	</script>
	<script is:inline>
	  document.addEventListener('DOMContentLoaded', () => {
	    const form = document.getElementById('leadForm');
	    const submitBtn = document.getElementById('submitBtn');
	    const btnText = document.getElementById('btnText');
	    const btnSpinner = document.getElementById('btnSpinner');
	    const feedback = document.getElementById('formFeedback');

	    if (form) {
	      form.addEventListener('submit', async (e) => {
	        e.preventDefault();
	        
	        // Bloquear botón y mostrar spinner (Fricción Cero UX)
	        submitBtn.disabled = true;
	        btnText.textContent = 'Enviando...';
	        btnSpinner.classList.remove('hidden');
	        feedback.classList.add('hidden');

	        const formData = new FormData(form);

	        try {
	          const response = await fetch('/api/cotizar', {
	            method: 'POST',
	            body: formData,
	          });

	          const result = await response.json();

	          feedback.classList.remove('hidden');
	          if (response.ok) {
	            feedback.className = "text-center text-sm font-semibold mt-4 text-green-600 bg-green-50 p-3 rounded border border-green-200";
	            feedback.textContent = "¡Cotización enviada con éxito! Nos comunicaremos de inmediato.";
	            form.reset();
	          } else {
	            feedback.className = "text-center text-sm font-semibold mt-4 text-red-600 bg-red-50 p-3 rounded border border-red-200";
	            feedback.textContent = result.message || "Hubo un error. Inténtalo de nuevo.";
	          }
	        } catch (error) {
	          feedback.classList.remove('hidden');
	          feedback.className = "text-center text-sm font-semibold mt-4 text-red-600 bg-red-50 p-3 rounded border border-red-200";
	          feedback.textContent = "Error de conexión. Revisa tu internet o intenta más tarde.";
	        } finally {
	          // Desbloquear botón
	          submitBtn.disabled = false;
	          btnText.textContent = 'Cotizar Ahora';
	          btnSpinner.classList.add('hidden');
	        }
	      });
	    }
	  });
	</script>
</Layout>
