---
---
<footer class="mt-auto border-t border-white/10 bg-black/20 pt-16 pb-8 relative overflow-hidden">
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[1000px] h-[300px] bg-[var(--color-brand-primary)]/10 blur-[120px] rounded-full pointer-events-none"></div>
  
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
      <div class="md:col-span-2">
        <div class="flex items-center gap-2 mb-6">
          <div class="w-8 h-8 rounded bg-[var(--color-brand-primary)] flex items-center justify-center font-bold text-white tracking-tighter">
            M
          </div>
          <span class="text-xl font-bold tracking-tight">MAFRA</span>
        </div>
        <p class="text-[var(--color-brand-text)] max-w-sm">
          Delivering premium logistics solutions with our signature zero friction approach. We move your world forward.
        </p>
      </div>
      
      <div>
        <h4 class="text-white font-semibold mb-4">Company</h4>
        <ul class="space-y-3">
          <li><a href="#" class="text-[var(--color-brand-text)] hover:text-white transition-colors">About Us</a></li>
          <li><a href="#" class="text-[var(--color-brand-text)] hover:text-white transition-colors">Careers</a></li>
          <li><a href="#" class="text-[var(--color-brand-text)] hover:text-white transition-colors">News</a></li>
          <li><a href="#" class="text-[var(--color-brand-text)] hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>
      
      <div>
        <h4 class="text-white font-semibold mb-4">Services</h4>
        <ul class="space-y-3">
          <li><a href="#" class="text-[var(--color-brand-text)] hover:text-white transition-colors">Freight Forwarding</a></li>
          <li><a href="#" class="text-[var(--color-brand-text)] hover:text-white transition-colors">Warehousing</a></li>
          <li><a href="#" class="text-[var(--color-brand-text)] hover:text-white transition-colors">Supply Chain</a></li>
          <li><a href="#" class="text-[var(--color-brand-text)] hover:text-white transition-colors">Customs</a></li>
        </ul>
      </div>
    </div>
    
    <div class="pt-8 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-[var(--color-brand-text)] text-sm">
        &copy; {new Date().getFullYear()} MAFRA Logistics. All rights reserved.
      </p>
      <div class="flex gap-4">
        <a href="#" class="text-[var(--color-brand-text)] hover:text-white transition-colors text-sm">Privacy Policy</a>
        <a href="#" class="text-[var(--color-brand-text)] hover:text-white transition-colors text-sm">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
