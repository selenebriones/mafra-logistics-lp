---
const features = [
  {
    title: "Global Reach",
    description: "Seamlessly connect your business to international markets with our extensive network.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/></svg>`
  },
  {
    title: "Real-time Tracking",
    description: "Monitor your cargo's journey at every stage with our advanced tracking systems.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>`
  },
  {
    title: "Zero Friction",
    description: "We handle the complexities so you can focus on scaling your business.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>`
  }
];
---
<section id="services" class="py-24 relative">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-bold mb-4 tracking-tight">Engineered for <span class="text-[var(--color-brand-primary)]">Excellence</span></h2>
      <p class="text-[var(--color-brand-text)] text-lg max-w-2xl mx-auto">Our infrastructure is designed to eliminate bottlenecks and accelerate your supply chain operations.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {features.map(feature => (
        <div class="glass-card p-8 rounded-2xl group hover:-translate-y-2 transition-transform duration-300">
          <div class="w-14 h-14 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-[var(--color-brand-primary)] mb-6 group-hover:scale-110 transition-transform duration-300" set:html={feature.icon} />
          <h3 class="text-xl font-bold mb-3 text-white">{feature.title}</h3>
          <p class="text-[var(--color-brand-text)] leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
