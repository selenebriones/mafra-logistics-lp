---
<section class="relative pt-32 pb-20 md:pt-48 md:pb-32 overflow-hidden flex items-center justify-center min-h-[90vh]">
  <!-- Decorative Background Elements -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-[var(--color-brand-primary)]/20 rounded-full blur-[120px] -z-10"></div>
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[var(--color-brand-secondary)]/30 rounded-full blur-[100px] -z-10"></div>
  
  <div class="max-w-7xl mx-auto px-6 relative z-10 text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/10 bg-white/5 mb-8 backdrop-blur-md">
      <span class="w-2 h-2 rounded-full bg-[var(--color-brand-primary)] animate-pulse"></span>
      <span class="text-xs font-medium tracking-wide uppercase text-[var(--color-brand-text)]">Zero Friction Philosophy</span>
    </div>
    
    <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight mb-6 leading-tight">
      Logistics without <br class="hidden md:block"/>
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-[var(--color-brand-text)]">the friction.</span>
    </h1>
    
    <p class="mt-6 text-lg md:text-xl text-[var(--color-brand-text)] max-w-2xl mx-auto font-light leading-relaxed mb-10">
      Premium supply chain solutions designed for maximum efficiency. Experience seamless transportation, warehousing, and global distribution.
    </p>
    
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#services" class="w-full sm:w-auto px-8 py-4 rounded-full bg-[var(--color-brand-primary)] hover:bg-[#c94556] text-white font-medium transition-all shadow-[0_0_30px_rgba(180,58,74,0.4)] flex items-center justify-center gap-2">
        Explore Services
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a href="#tracking" class="w-full sm:w-auto px-8 py-4 rounded-full bg-white/5 hover:bg-white/10 border border-white/10 text-white font-medium transition-all flex items-center justify-center gap-2 glass-card">
        Track Shipment
      </a>
    </div>
  </div>
</section>
