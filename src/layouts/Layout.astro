---
import '../styles/global.css';
interface Props {
	title: string;
}
const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Respondemos a tus fletes urgentes en Nuevo León con flota propia. Disponibilidad inmediata 24/7." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
		<script src="https://unpkg.com/@phosphor-icons/web"></script>
		<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
		<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
	</head>
	<body class="bg-brand-light text-brand-dark font-display antialiased overflow-x-hidden">
		
		<header class="bg-white border-b border-black/10 fixed top-0 left-0 w-full z-50 transition-all duration-300 py-5 shadow-md">
			<div class="max-w-7xl mx-auto px-6 flex justify-between items-center">
				<a href="#" class="flex items-center gap-2">
					<img src="/logo.png" alt="MAFRA Logistics" class="h-14 w-auto" />
				</a>
				<nav class="hidden md:flex items-center gap-8 text-sm font-semibold text-brand-secondary">
					<a href="#por-que-elegirnos" class="hover:text-brand-primary transition-colors">Beneficios</a>
					<a href="#soluciones" class="hover:text-brand-primary transition-colors">Soluciones de Carga</a>
					<a href="#cotizar" class="hover:text-brand-primary transition-colors">Cotizar</a>
				</nav>
				
				<!-- Mobile Menu Toggle -->
				<button id="mobile-menu-btn" class="md:hidden text-brand-dark p-2 focus:outline-none">
					<i class="ph ph-list text-3xl" id="mobile-menu-icon"></i>
				</button>
			</div>

			<!-- Mobile Menu Dropdown -->
			<div id="mobile-menu" class="absolute top-full left-0 w-full bg-white border-b border-black/10 shadow-xl hidden flex-col py-6 px-6 gap-6 md:hidden">
				<a href="#por-que-elegirnos" class="mobile-link text-lg font-semibold text-brand-secondary">Beneficios</a>
				<a href="#soluciones" class="mobile-link text-lg font-semibold text-brand-secondary">Soluciones de Carga</a>
				<a href="#cotizar" class="mobile-link text-lg font-semibold text-brand-primary">Cotizar</a>
			</div>
		</header>

		<slot />

		<footer class="bg-brand-dark text-white pt-16 pb-8 border-t border-white/10">
			<div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
				<div>
					<img src="/White-logo.png" alt="MAFRA Logistics" class="h-16 w-auto mb-6 opacity-90" />
					<p class="text-brand-text text-sm leading-relaxed">Tu aliado estratégico en transporte logístico B2B que responde cuando otros te quedan mal.</p>
				</div>
				<div>
					<h4 class="text-lg font-bold mb-4 text-brand-primary">Datos de Contacto</h4>
					<ul class="space-y-3 text-sm text-brand-text">
						<li class="flex items-center gap-2"><i class="ph ph-phone text-brand-primary"></i> Ventas México: +52 812-911-5812</li>
						<li class="flex items-center gap-2"><i class="ph ph-envelope text-brand-primary"></i> sales@mafragrp.com</li>
						<li class="flex items-center gap-2"><i class="ph ph-map-pin text-brand-primary"></i> Cordillera del Himalaya 914, San Nicolás de los Garza, NL.</li>
					</ul>
				</div>
				<div>
					<h4 class="text-lg font-bold mb-4 text-white">Legal</h4>
					<div class="flex flex-col gap-2 text-sm text-brand-text">
						<a href="#" class="hover:text-white transition-colors">Aviso de Privacidad</a>
						<a href="#" class="hover:text-white transition-colors">Términos y Condiciones</a>
					</div>
				</div>
			</div>
			<div class="max-w-7xl mx-auto px-6 pt-8 border-t border-white/5 text-center text-xs text-brand-text">
				<p>2026 Mafra Logistics. Todos los derechos reservados.</p>
			</div>
		</footer>

		<!-- Chatbot Aislado (Evita colisión de CSS) -->
		<iframe id="chatbot-iframe" src="/chatbot.html" title="Chatbot" style="position: fixed; bottom: 0; right: 0; width: 120px; height: 120px; border: none; z-index: 999999; background: transparent; transition: all 0.3s ease;"></iframe>
		<script is:inline>
			window.addEventListener('message', function(e) {
				const iframe = document.getElementById('chatbot-iframe');
				if (!iframe) return;
				
				if (e.data === 'chat_open') {
					iframe.style.width = '100vw';
					iframe.style.height = '100vh';
				} else if (e.data === 'chat_closed') {
					iframe.style.width = '120px';
					iframe.style.height = '120px';
				}
			});

			// Script para el menú móvil
			const btn = document.getElementById('mobile-menu-btn');
			const menu = document.getElementById('mobile-menu');
			const icon = document.getElementById('mobile-menu-icon');
			const links = document.querySelectorAll('.mobile-link');

			if (btn && menu && icon) {
				btn.addEventListener('click', () => {
					menu.classList.toggle('hidden');
					menu.classList.toggle('flex');
					if (menu.classList.contains('hidden')) {
						icon.classList.remove('ph-x');
						icon.classList.add('ph-list');
					} else {
						icon.classList.remove('ph-list');
						icon.classList.add('ph-x');
					}
				});

				// Cerrar menú al hacer clic en un enlace
				links.forEach(link => {
					link.addEventListener('click', () => {
						menu.classList.add('hidden');
						menu.classList.remove('flex');
						icon.classList.remove('ph-x');
						icon.classList.add('ph-list');
					});
				});
			}
		</script>
	</body>
</html>
